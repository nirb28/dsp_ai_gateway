{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "7.3.7"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "graph",
      "name": "Graph",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "${DS_PROMETHEUS}",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Manifest-level metrics (top category) for APISIX routes.",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "iteration": 1,
  "links": [],
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(apisix_http_status{route=~\"${manifest}-.*\"})",
          "refId": "A"
        }
      ],
      "title": "Total Requests (Manifest)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{route=~\"${manifest}-.*\"}[5m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "title": "Requests / sec",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (code) (rate(apisix_http_status{route=~\"${manifest}-.*\"}[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "Status Codes (RPS)",
      "type": "graph"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (type) (rate(apisix_bandwidth{route=~\"${manifest}-.*\"}[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "title": "Bandwidth (Bytes/sec)",
      "type": "graph"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(apisix_http_latency_bucket{route=~\"${manifest}-.*\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apisix_http_latency_bucket{route=~\"${manifest}-.*\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apisix_http_latency_bucket{route=~\"${manifest}-.*\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Request Latency (Seconds)",
      "type": "graph"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (subcategory) (label_replace(rate(apisix_http_status{route=~\"${manifest}-.*\"}[5m]), \"subcategory\", \"$1\", \"route\", \"^[^-]+-(.*)$\"))",
          "legendFormat": "{{subcategory}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Subcategory (Rest of ID)",
      "type": "graph"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": [
    "apisix",
    "manifest"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(apisix_http_status, route)",
        "hide": 0,
        "includeAll": true,
        "label": "Manifest (Top)",
        "multi": false,
        "name": "manifest",
        "options": [],
        "query": {
          "query": "label_values(apisix_http_status, route)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "/^([^-]+)-.*$/",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "APISIX Manifest Metrics (Top-Level)",
  "uid": "apisix-manifest-top",
  "version": 1
}
